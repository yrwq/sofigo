{
  "name": "sofigo",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "backend",
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --continue=always",
    "dev:backend": "bun run --cwd backend dev",
    "dev:mobile": "bun run --cwd mobile dev",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter=backend",
    "build:mobile": "turbo run build --filter=mobile",
    "lint": "turbo run lint",
    "lint:backend": "turbo run lint --filter=backend",
    "lint:mobile": "turbo run lint --filter=mobile",
    "check": "biome check .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "test:backend": "turbo run test --filter=backend",
    "db:schema": "bun run --cwd backend db:schema",
    "gtfs:import": "bun run --cwd backend gtfs:import",
    "typecheck": "turbo run typecheck",
    "typecheck:backend": "turbo run typecheck --filter=backend",
    "typecheck:mobile": "turbo run typecheck --filter=mobile"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "turbo": "^2.8.12",
    "typescript": "^5.9.2"
  }
}
